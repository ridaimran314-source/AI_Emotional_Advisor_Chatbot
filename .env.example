# Environment
FLASK_ENV=development
FLASK_SECRET_KEY=change_this_secret

# AI Provider: groq | gemini | openrouter | huggingface
AI_PROVIDER=groq
AI_API_KEY=your_api_key_here
AI_MODEL=llama-3.1-8b-instant

# App settings
MAX_USER_MESSAGE_LENGTH=1000
APP_NAME=AI Emotional Advisor

# Provider-specific model examples:
# Groq:        llama-3.1-8b-instant, mixtral-8x7b-32768
# Gemini:      gemini-1.5-flash, gemini-1.5-pro
# OpenRouter:  meta-llama/llama-3.1-8b-instruct:free
# HuggingFace: microsoft/DialoGPT-medium (model path as ID)
